{
  "expo": {
    "name": "QUADS",
    "slug": "campus-marketplace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quads.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.quads.app"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#ff6b6b",
      "iosDisplayInForeground": true
    },
    "scheme": "quads",
    "extra": {
      "apiUrl": "https://api.quadsmarket.tech/api",
      "socketUrl": "https://api.quadsmarket.tech",
      "supabaseUrl": "https://dbxeaqwjihgppffdcbdd.supabase.co",
      "supabaseKey": "sb_publishable_J-MSyIozalEGlIPvevfLow_FwN682H6",
      "eas": {
        "projectId": "59ecf4f8-6c74-4eca-b11f-e6e2b74c8619"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-camera",
      "expo-font",
      "@sentry/react-native"
    ],
    "owner": "richieroidev"
  }
}