{
  "name": "quads",
  "version": "1.0.0",
  "description": "QUADS - The Official Institutional Marketplace",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "dev:mobile": "npm run start --workspace=mobile",
    "build:server": "npm run build --workspace=server",
    "build:web": "npm run build --workspace=web",
    "sync-env": "node scripts/sync-env.js",
    "price-check": "node server/src/scripts/price-check.cron.js",
    "predev": "npm run sync-env",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "start": "npm start --workspace=server",
    "lint": "eslint . --ext .ts,.tsx,.js --quiet && prettier --check .",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix && prettier --write .",
    "test": "npm run test --workspace=server"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  }
}
