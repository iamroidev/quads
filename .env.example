# ============================================
# CampusMarketplace - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# ALL packages (server, web, mobile) read from
# this single root .env file.
#
# For production deployments, create package-level
# overrides only if needed (e.g., web/.env.production
# for Vite-specific vars that differ from dev).
# ============================================

# ─── Server ─────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/campusmarketplace
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ─── Supabase ───────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ─── Cloudinary ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Paystack ───────────────────────────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# ─── Google OAuth ───────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_IDS=comma,separated,ids

# ─── Client ─────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── SMTP (Resend) ──────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# ─── Clerk Auth ─────────────────────────────────
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# ─── Firebase Admin (Server) ────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# ─── Web Push (VAPID) ────────────────────────────
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ─── AWS SNS (SMS) ──────────────────────────────
AWS_REGION=us-east-1
AWS_SNS_SENDER_ID=YOUR_APP

# ─── Platform ───────────────────────────────────
PLATFORM_COMMISSION=10

# ─── Vite (Web App - VITE_* prefixed) ──────────
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_KEY=your_supabase_anon_key
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ─── Expo (Mobile App - EXPO_PUBLIC_* prefixed) ─
EXPO_PUBLIC_API_URL=http://localhost:5000/api
EXPO_PUBLIC_SOCKET_URL=http://localhost:5000
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_KEY=your_supabase_anon_key