{
  "expo": {
    "name": "QUADS",
    "slug": "campus-marketplace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quads.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.quads.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#ff6b6b",
      "iosDisplayInForeground": true
    },
    "scheme": [
      "quads",
      "com.googleusercontent.apps.912061029071-9cu0hecip5gl1qbkq6mmpm6bsk9nlfa7"
    ],
    "extra": {
      "apiUrl": "https://api.quadsmarket.tech/api",
      "socketUrl": "https://api.quadsmarket.tech",
      "eas": {
        "projectId": "59ecf4f8-6c74-4eca-b11f-e6e2b74c8619"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-camera",
      "expo-font"
    ],
    "owner": "richieroidev",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/59ecf4f8-6c74-4eca-b11f-e6e2b74c8619"
    }
  }
}
